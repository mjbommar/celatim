{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/celatim/detector-replay-corpus-v1.schema.json",
  "title": "celatim detector replay corpus result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_unix_s",
    "ok",
    "command",
    "trace_count",
    "ok_trace_count",
    "failed_trace_count",
    "mechanism_count",
    "result_count",
    "executed_count",
    "failed_count",
    "matched_mechanism_count",
    "checked_unit_count",
    "matched_unit_count",
    "aggregate_matched_rate",
    "false_positive_estimate",
    "false_positive_claim_status",
    "false_positive_claim_blockers",
    "aggregate_false_positive_rate",
    "trace_source_kind_counts",
    "traces"
  ],
  "properties": {
    "schema_version": { "const": "celatim.detector_replay_corpus.v1" },
    "generated_at_unix_s": { "type": "number" },
    "ok": { "type": "boolean" },
    "command": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trace_count": { "type": "integer" },
    "ok_trace_count": { "type": "integer" },
    "failed_trace_count": { "type": "integer" },
    "mechanism_count": { "type": "integer" },
    "result_count": { "type": "integer" },
    "executed_count": { "type": "integer" },
    "failed_count": { "type": "integer" },
    "matched_mechanism_count": { "type": "integer" },
    "checked_unit_count": { "type": "integer" },
    "matched_unit_count": { "type": "integer" },
    "aggregate_matched_rate": { "type": ["number", "null"] },
    "false_positive_estimate": { "type": "boolean" },
    "false_positive_claim_status": {
      "enum": ["false_positive_estimate_ready", "not_false_positive_estimate"]
    },
    "false_positive_claim_blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/false_positive_claim_blocker" }
    },
    "aggregate_false_positive_rate": { "type": ["number", "null"] },
    "trace_source_kind_counts": { "type": "object" },
    "traces": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace_summary" }
    }
  },
  "$defs": {
    "false_positive_claim_blocker": {
      "enum": [
        "not_false_positive_source",
        "missing_trace_name",
        "missing_trace_license",
        "missing_filtering_assumptions",
        "missing_public_trace_origin",
        "detector_execution_incomplete",
        "empty_mechanism_set",
        "empty_trace_corpus"
      ]
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes",
        "packet_count",
        "source_kind",
        "trace_name",
        "origin_url",
        "license",
        "filtering_assumptions"
      ],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size_bytes": { "type": "integer" },
        "packet_count": { "type": "integer" },
        "source_kind": {
          "enum": [
            "public_benign_trace",
            "authorized_benign_trace",
            "local_generated_control",
            "scenario_control_fixture",
            "unknown"
          ]
        },
        "trace_name": { "type": ["string", "null"] },
        "origin_url": { "type": ["string", "null"] },
        "license": { "type": ["string", "null"] },
        "filtering_assumptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "trace_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace",
        "ok",
        "mechanism_count",
        "executed_count",
        "failed_count",
        "matched_mechanism_count",
        "checked_unit_count",
        "matched_unit_count",
        "aggregate_matched_rate",
        "false_positive_estimate",
        "false_positive_claim_status",
        "false_positive_claim_blockers",
        "aggregate_false_positive_rate"
      ],
      "properties": {
        "trace": { "$ref": "#/$defs/trace" },
        "ok": { "type": "boolean" },
        "mechanism_count": { "type": "integer" },
        "executed_count": { "type": "integer" },
        "failed_count": { "type": "integer" },
        "matched_mechanism_count": { "type": "integer" },
        "checked_unit_count": { "type": "integer" },
        "matched_unit_count": { "type": "integer" },
        "aggregate_matched_rate": { "type": ["number", "null"] },
        "false_positive_estimate": { "type": "boolean" },
        "false_positive_claim_status": {
          "enum": ["false_positive_estimate_ready", "not_false_positive_estimate"]
        },
        "false_positive_claim_blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/false_positive_claim_blocker" }
        },
        "aggregate_false_positive_rate": { "type": ["number", "null"] }
      }
    }
  }
}
