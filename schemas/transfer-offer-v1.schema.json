{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://celatim.org/schemas/transfer-offer-v1.schema.json",
  "title": "celatim transfer offer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "offer_id",
    "host",
    "port",
    "expires_at",
    "tls_cert_sha256",
    "access_token",
    "providers",
    "max_file_size",
    "trust_mode",
    "receiver_label"
  ],
  "properties": {
    "schema_version": {"const": "celatim.transfer_offer.v1"},
    "offer_id": {"type": "string", "format": "uuid"},
    "host": {"type": "string", "minLength": 1, "maxLength": 253},
    "port": {"type": "integer", "minimum": 1, "maximum": 65535},
    "expires_at": {"type": "string", "format": "date-time"},
    "tls_cert_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "access_token": {"type": "string", "pattern": "^[A-Za-z0-9_-]{32,128}$"},
    "providers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}
    },
    "max_file_size": {"type": "integer", "minimum": 1, "maximum": 1099511627776},
    "trust_mode": {"enum": ["offer_bound", "verified_contact"]},
    "receiver_label": {"type": ["string", "null"], "minLength": 1, "maxLength": 128}
  }
}
