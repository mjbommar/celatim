FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /work

ARG CELATIM_SOURCE=.
COPY ${CELATIM_SOURCE} /work/celatim

RUN python -m pip install --upgrade pip \
    && python -m pip install -e "/work/celatim[packet,crypto,daemon,dns,ssh,iot,realtime]"

ENV PATH="/usr/local/bin:${PATH}"
