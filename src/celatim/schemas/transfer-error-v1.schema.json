{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://celatim.org/schemas/transfer-error-v1.schema.json",
  "title": "celatim transfer error",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "code", "detail", "retryable", "resumable", "next_action"],
  "properties": {
    "schema_version": {"const": "celatim.transfer_error.v1"},
    "code": {
      "enum": [
        "input_invalid",
        "offer_invalid",
        "offer_expired",
        "offer_replayed",
        "trust_failed",
        "policy_blocked",
        "crypto_unavailable",
        "crypto_failed",
        "provider_unavailable",
        "provider_incompatible",
        "privilege_required",
        "network_failed",
        "timeout",
        "integrity_failed",
        "storage_failed",
        "compatibility_failed",
        "cancelled",
        "internal_error"
      ]
    },
    "detail": {"type": "string", "minLength": 1, "maxLength": 512},
    "retryable": {"type": "boolean"},
    "resumable": {"type": "boolean"},
    "next_action": {"type": "string", "minLength": 1, "maxLength": 512}
  }
}
