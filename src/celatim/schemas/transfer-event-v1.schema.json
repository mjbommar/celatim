{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://celatim.org/schemas/transfer-event-v1.schema.json",
  "title": "celatim transfer event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sequence",
    "transfer_id",
    "kind",
    "status",
    "timestamp",
    "provider",
    "bytes_transferred",
    "total_bytes",
    "chunk_index",
    "retry_count",
    "message",
    "error_code"
  ],
  "properties": {
    "schema_version": {"const": "celatim.transfer_event.v1"},
    "sequence": {"type": "integer", "minimum": 0},
    "transfer_id": {"type": "string", "format": "uuid"},
    "kind": {"enum": ["state", "progress", "retry", "warning", "completed", "failed"]},
    "status": {
      "enum": [
        "created",
        "preflighting",
        "negotiating",
        "handshaking",
        "transferring",
        "paused",
        "verifying",
        "finalizing",
        "completed",
        "cancelled",
        "expired",
        "failed",
        "quarantined"
      ]
    },
    "timestamp": {"type": "string", "format": "date-time"},
    "provider": {"type": ["string", "null"], "maxLength": 64},
    "bytes_transferred": {"type": "integer", "minimum": 0},
    "total_bytes": {"type": ["integer", "null"], "minimum": 0},
    "chunk_index": {"type": ["integer", "null"], "minimum": 0},
    "retry_count": {"type": "integer", "minimum": 0},
    "message": {"type": ["string", "null"], "maxLength": 512},
    "error_code": {"type": ["string", "null"], "maxLength": 64}
  }
}
